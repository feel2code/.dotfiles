set $mod Mod1
font pango:JetBrainsMono Nerd Font 8
exec --no-startup-id dex --autostart --environment i3
# Set default terminal
set $TERMINAL kitty
exec_always --no-startup-id "export TERMINAL=$TERMINAL"
# Start picom compositor
exec_always --no-startup-id picom --backend xrender --config ~/.config/picom/picom.conf -b
exec --no-startup-id nm-applet
exec blueman-applet
# notifications control
exec_always --no-startup-id dunst
bindsym $mod+equal exec dunstctl history-pop
bindsym $mod+minus exec dunstctl close-all
# brightness control
bindsym XF86MonBrightnessUp   exec --no-startup-id brightnessctl set +10%
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl set 10%-
# Use pactl to adjust volume in PulseAudio.
# set $refresh_i3status killall -SIGUSR1 i3status
bindsym XF86AudioRaiseVolume exec --no-startup-id systemd-run --user --collect --quiet /usr/bin/wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.1+
bindsym XF86AudioLowerVolume exec --no-startup-id systemd-run --user --collect --quiet /usr/bin/wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.1-
bindsym XF86AudioMute        exec --no-startup-id systemd-run --user --collect --quiet /usr/bin/wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym XF86AudioMicMute     exec --no-startup-id systemd-run --user --collect --quiet /usr/bin/wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle

floating_modifier $mod
tiling_drag modifier titlebar
# start a terminal
bindsym $mod+Return exec $TERMINAL
# kill focused window
bindsym $mod+q kill
# start dmenu (a program launcher)
bindsym $mod+d exec --no-startup-id dmenu_run
# displays
# exec xrandr --output DP-0 --primary --mode 2560x1440
# make pip run in any frames
for_window [title="Picture-in-Picture"] sticky enable
# change focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
# move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right
# split in horizontal/vertical orientation
bindsym $mod+Ctrl+h split h
bindsym $mod+v split v
# enter fullscreen mode for the focused container
bindsym $mod+f fullscreen toggle
# toggle tiling / floating
bindsym $mod+Shift+space floating toggle
# workspaces
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
# switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
# move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
# reload/restart the configuration file
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
# exit i3 (logs you out of your X session)
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'This will end your X session.' -B 'Yes, exit i3' 'i3-msg exit'"
# resize window (you can also use the mouse for that)
mode "resize" {
        bindsym h resize shrink width 10 px or 10 ppt
        bindsym j resize grow height 10 px or 10 ppt
        bindsym k resize shrink height 10 px or 10 ppt
        bindsym l resize grow width 10 px or 10 ppt
        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}
bindsym $mod+r mode "resize"
default_border pixel 4
bar {
  position top
	status_command i3status
	font pango:JetBrainsMono Nerd Font 12
	colors {
		focused_workspace #000000 #666666 #ffffff
	}
}

# touchpad
exec --no-startup-id xinput set-prop "Synaptics TM3276-022" "libinput Natural Scrolling Enabled" 1
exec --no-startup-id xinput set-prop "Synaptics TM3276-022" "libinput Tapping Enabled" 1

bindsym Print exec flameshot gui
exec sxhkd
exec x11vnc -forever -loop -noxdamage
exec --no-startup-id nm-applet
exec --no-startup-id xfce4-power-manager
exec --no-startup-id flameshot
exec --no-startup-id feh --bg-scale /home/$USER/Pictures/wallpapers/Anime-Girl2.png
exec --no-startup-id kitty sh -c 'tmux attach -t dev || tmux new -s dev'
exec --no-startup-id chromium
exec --no-startup-id slack
